{
  "name": "com.corrugator.systemusage",
  "version": "1.0.0",
  "description": "Stream Deck plugin showing macOS memory pressure and CPU usage as colored percentages",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "validate": "npx @elgato/cli validate com.corrugator.systemusage.sdPlugin",
    "pack": "npm run build && npx @elgato/cli pack -f -o dist com.corrugator.systemusage.sdPlugin"
  },
  "keywords": [
    "streamdeck",
    "system",
    "cpu",
    "memory",
    "ram",
    "macos"
  ],
  "author": "Corrugator",
  "license": "ISC",
  "dependencies": {
    "@elgato/streamdeck": "^2.0.4"
  },
  "devDependencies": {
    "@elgato/cli": "^1.7.3",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^20.19.43",
    "rollup": "^4.60.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3"
  }
}
